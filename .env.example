# -----------------------------------------------------------------------------
# 5 Minute Dungeon — Environment Variables
# -----------------------------------------------------------------------------

# PartyKit
# The URL of your deployed PartyKit server (or localhost during dev)
# Local: 127.0.0.1:1999
# Prod: https://YOUR_PARTYKIT_DOMAIN.partykit.dev
NEXT_PUBLIC_PARTYKIT_HOST=""

# Supabase
# Your Supabase Project URL
# Local: http://127.0.0.1:54321
# Prod: https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=""

# Supabase Anon Key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Supabase Service Role Key (SERVER SIDE ONLY - NEVER EXPOSE TO CLIENT)
# Used for backend API routes that bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=""
